# Full site URL including subfolder, OR domain only (auto-adds /new from APP_BASE_PATH)
APP_URL=https://blueaxislog.com/new
# Install folder path (no trailing slash). Use /new when site is at domain.com/new/
APP_BASE_PATH=/new
# Optional: override public folder web path (default: {APP_BASE_PATH}/public)
# APP_PUBLIC_PATH=/new/public
APP_ENV=local
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=blueaxis
DB_USERNAME=root
DB_PASSWORD=

# Admin login is stored in the database (admins table), not read from .env at runtime.
# After install: admin@blueaxis.com / ChangeMe123! — change with:
#   php database/set-admin-password.php admin@blueaxis.com 'YourSecurePassword'

# Mail — lead notifications (contact + quote forms)
# driver: mail (PHP mail()) or smtp
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@blueaxis.com
MAIL_FROM_NAME=BlueAxis Website
MAIL_NOTIFY_TO=info@blueaxis.com
MAIL_NOTIFY_CONTACT=true
MAIL_NOTIFY_QUOTE=true
MAIL_REPLY_TO_LEAD=true
